# Copy this file to .env and fill in your values
# (never commit .env to git)

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key — used for Whisper podcast transcription
# Get from platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Gmail sending credentials
# EMAIL_FROM must be a Gmail address
# GMAIL_APP_PASSWORD: generate at myaccount.google.com > Security > App passwords
#   (requires 2FA to be enabled on the account)
EMAIL_FROM=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Recipients — comma-separated for multiple addresses
EMAIL_TO=damion.moore@viasat.com,mtbdcm4lf@gmail.com
